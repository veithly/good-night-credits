# Good Night Credits
# Copy to `.env.local` for local Next.js development.
# Cloudflare local preview uses `.dev.vars` / Wrangler secrets instead.

# Single public model gateway. The UI and API only expose MODEL_GATEWAY_MODEL.
MODEL_GATEWAY_API_KEY=
MODEL_GATEWAY_BASE_URL=https://api.example.com/v1
MODEL_GATEWAY_MODEL=your-model-id

# Browser-safe app config.
NEXT_PUBLIC_DEMO_MODE=1
NEXT_PUBLIC_APP_NAME=Good Night Credits
